{
  "name": "dermacity",
  "version": "1.0.0",
  "description": "Dermacity - Duoc My Pham Da Lieu",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names \"BACKEND,FRONTEND\" --prefix-colors \"bgCyan.black,bgMagenta.black\" \"npm run backend\" \"npm run frontend\"",
    "backend": "cd backend && php artisan serve --port=8000",
    "frontend": "npm run dev --prefix frontend",
    "install:all": "npm install --prefix frontend && cd backend && composer install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
